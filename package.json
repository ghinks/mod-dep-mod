{
  "name": "mod-dep-mod",
  "version": "3.0.0",
  "description": "A tool to scan the dependency tree at the registry",
  "type": "module",
  "bin": {
    "mod-dep-mod": "bin/index.js"
  },
  "scripts": {
    "build": "npx babel src --out-dir lib --ignore \"src/**/test.js\"",
    "watch": "npx babel --watch src --out-dir lib --ignore \"src/**/test.js\"",
    "lint": "npx standard --env mocha src/**/*.js",
    "test": "cross-env NODE_ENV=test npx mocha --loader=testdouble --timeout 4000 src/**/*test.js"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghinks/mod-dep-mod.git"
  },
  "keywords": [
    "search",
    "find",
    "module",
    "dependencies",
    "dependency",
    "tree",
    "dep",
    "compliance",
    "risk",
    "security"
  ],
  "author": "Glenn Hinks",
  "license": "ISC",
  "dependencies": {
    "async": "3.2.0",
    "isomorphic-fetch": "3.0.0",
    "minimist": "1.2.5",
    "npm-package-arg": "8.1.2",
    "ora": "5.4.0",
    "pify": "5.0.0",
    "read-package-json": "3.0.1",
    "registry-url": "6.0.0",
    "semver": "7.3.5"
  },
  "devDependencies": {
    "chai": "4.3.4",
    "cross-env": "7.0.3",
    "mocha": "8.3.2",
    "nock": "13.0.11",
    "nodemon": "2.0.7",
    "nyc": "15.1.0",
    "standard": "16.0.3",
    "testdouble": "^3.16.1"
  },
  "standard": {
    "env": {
      "mocha": true
    }
  }
}
